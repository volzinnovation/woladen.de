# Isolated container state. This is a tmpfs volume from compose.yml, not repo data
# and not production state.
WOLADEN_LIVE_DB_PATH=/var/lib/woladen/live_state.sqlite3
WOLADEN_LIVE_RAW_PAYLOAD_DIR=/var/lib/woladen/live_raw
WOLADEN_LIVE_ARCHIVE_DIR=/var/lib/woladen/live_archives
WOLADEN_LIVE_QUEUE_DIR=/var/lib/woladen/live_queue

# Static metadata copied into the local image.
WOLADEN_LIVE_PROVIDER_CONFIG_PATH=/app/data/mobilithek_afir_provider_configs.json
WOLADEN_LIVE_PROVIDER_OVERRIDE_PATH=/app/data/live_provider_overrides.json
WOLADEN_LIVE_SITE_MATCH_PATH=/app/data/mobilithek_afir_static_matches.csv
WOLADEN_LIVE_CHARGERS_CSV_PATH=/app/data/chargers_fast.csv
WOLADEN_LIVE_FULL_CHARGERS_CSV_PATH=/app/data/chargers_full.csv
WOLADEN_LIVE_CHARGERS_GEOJSON_PATH=/app/data/chargers_fast.geojson

# Mounted read-only from host paths in compose.yml.
WOLADEN_LIVE_SUBSCRIPTION_REGISTRY_PATH=/run/secrets/woladen/mobilithek_subscriptions.json
WOLADEN_MACHINE_CERT_P12=/run/secrets/woladen/certificate.p12
WOLADEN_MACHINE_CERT_PASSWORD_FILE=/run/secrets/woladen/pwd.txt

# Local API only. Push routes are disabled in this constrained environment.
WOLADEN_LIVE_API_HOST=0.0.0.0
WOLADEN_LIVE_API_PORT=8001
WOLADEN_LIVE_API_PUSH_ENABLED=0
WOLADEN_LIVE_API_CORS_ALLOW_ORIGIN_REGEX=https?://(localhost|127\\.0\\.0\\.1|0\\.0\\.0\\.0|\\[::1\\])(\\:\\d+)?$

# Keep local pull tests bounded and avoid production archive uploads.
WOLADEN_LIVE_POLL_TIMEOUT_SECONDS=10
WOLADEN_LIVE_SQLITE_BUSY_TIMEOUT_MS=5000
WOLADEN_LIVE_SQLITE_LOCK_RETRY_SECONDS=30
WOLADEN_LIVE_QUEUE_CLEANUP_INTERVAL_SECONDS=60
WOLADEN_LIVE_QUEUE_DONE_RETENTION_SECONDS=3600
WOLADEN_LIVE_QUEUE_FAILED_RETENTION_SECONDS=86400
WOLADEN_LIVE_ARCHIVE_TIMEZONE=Europe/Berlin
WOLADEN_LIVE_HF_ARCHIVE_REPO_ID=
WOLADEN_LIVE_HF_ARCHIVE_TOKEN_FILE=
