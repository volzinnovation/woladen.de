# Runtime paths
WOLADEN_LIVE_DB_PATH=/var/lib/woladen/live_state.sqlite3
# Provider response logs are written as timestamped JSON files below this directory.
WOLADEN_LIVE_RAW_PAYLOAD_DIR=/var/lib/woladen/live_raw
WOLADEN_LIVE_ARCHIVE_DIR=/var/lib/woladen/live_archives
WOLADEN_LIVE_PROVIDER_CONFIG_PATH=/srv/woladen-live/current/data/mobilithek_afir_provider_configs.json
WOLADEN_LIVE_SITE_MATCH_PATH=/srv/woladen-live/current/data/mobilithek_afir_static_matches.csv
WOLADEN_LIVE_CHARGERS_CSV_PATH=/srv/woladen-live/current/data/chargers_fast.csv
# Optional:
# WOLADEN_LIVE_PROVIDER_OVERRIDE_PATH=/srv/woladen-live/current/data/live_provider_overrides.json

# Mobilithek credentials and subscription state
WOLADEN_LIVE_SUBSCRIPTION_REGISTRY_PATH=/etc/woladen/mobilithek_subscriptions.json
WOLADEN_MACHINE_CERT_P12=/etc/woladen/certificate.p12
WOLADEN_MACHINE_CERT_PASSWORD_FILE=/etc/woladen/pwd.txt

# API process
WOLADEN_LIVE_API_HOST=127.0.0.1
WOLADEN_LIVE_API_PORT=8001
WOLADEN_LIVE_POLL_TIMEOUT_SECONDS=10
WOLADEN_LIVE_SQLITE_BUSY_TIMEOUT_MS=5000

# Frontend access from https://woladen.de
WOLADEN_LIVE_API_CORS_ALLOWED_ORIGINS=https://woladen.de,https://www.woladen.de
WOLADEN_LIVE_API_CORS_ALLOW_ORIGIN_REGEX=https?://(localhost|127\\.0\\.0\\.1)(:\\d+)?$

# Daily response archive upload to Hugging Face Hub
WOLADEN_LIVE_ARCHIVE_TIMEZONE=Europe/Berlin
# WOLADEN_LIVE_HF_ARCHIVE_REPO_ID=your-account-or-org/woladen-live-archives
WOLADEN_LIVE_HF_ARCHIVE_REPO_TYPE=dataset
WOLADEN_LIVE_HF_ARCHIVE_PATH_PREFIX=provider-response-archives
# WOLADEN_LIVE_HF_ARCHIVE_TOKEN_FILE=/etc/woladen/huggingface.token
